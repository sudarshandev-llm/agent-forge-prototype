# Build & install stage
FROM node:20-alpine AS build
WORKDIR /app

COPY package.json tsconfig.base.json turbo.json ./
COPY packages/shared/package.json packages/shared/
COPY apps/api/package.json apps/api/

RUN npm ci

COPY . .

RUN npm run build -w packages/shared
RUN npm run build -w apps/api
RUN npx prisma generate --schema apps/api/prisma/schema.prisma

# Production stage
FROM node:20-alpine AS production
WORKDIR /app
ENV NODE_ENV=production

COPY --from=build /app/apps/api/dist ./dist
COPY --from=build /app/apps/api/package.json ./
COPY --from=build /app/packages/shared/dist ./node_modules/@agentforge/shared/dist
COPY --from=build /app/packages/shared/package.json ./node_modules/@agentforge/shared/package.json
COPY --from=build /app/node_modules ./node_modules

EXPOSE 4000
CMD ["node", "dist/index.js"]
